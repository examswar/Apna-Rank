# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ── Database (Neon Serverless Postgres) ───────────────────────
# Pooled connection — use for all app queries (PgBouncer)
DATABASE_URL="postgresql://USER:PASS@HOST/DBNAME?pgbouncer=true&connection_limit=1"
# Direct connection — use for migrations & transactions
DIRECT_DATABASE_URL="postgresql://USER:PASS@HOST/DBNAME"

# ── JWT (RS256 asymmetric keypair) ────────────────────────────
# Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM — Railway stores \n as literal \n, the app normalises them.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Redis (Upstash) ───────────────────────────────────────────
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ── MSG91 (OTP SMS delivery) ──────────────────────────────────
MSG91_AUTH_KEY="your_msg91_auth_key"
MSG91_TEMPLATE_ID="your_otp_template_id"

# ── Claude API (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ── Cloudflare R2 (S3-compatible file storage) ────────────────
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="apna-rank-assets"
R2_PUBLIC_URL="https://cdn.apnarank.in"

# ── Field Encryption (AES-256-GCM) ───────────────────────────
# Used for PAN numbers and guardian phone numbers (DPDP compliance)
# Generate: openssl rand -hex 32
FIELD_ENCRYPTION_KEY="64_char_hex_string_here"

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"

# Reverse-proxy hops in front of the app (1 = single load balancer). Sets
# Fastify trustProxy so req.ip is the real client IP and can't be forged via
# X-Forwarded-For. MUST match your deployment topology.
TRUSTED_PROXY_HOPS="1"

# Local-dev ONLY: store OTPs in memory + print them to the console and skip the
# real SMS send. Defaults false and is ignored when NODE_ENV=production. There is
# no master/bypass OTP — leave this false anywhere real users exist.
AUTH_DEV_OTP="false"

# ── App ───────────────────────────────────────────────────────
# Base URL used for invite links (battle challenge share URLs)
APP_BASE_URL="http://localhost:3000"

# ── Sentry (optional error tracking) ─────────────────────────
SENTRY_DSN=""
