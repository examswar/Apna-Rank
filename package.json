{
  "name": "apna-rank",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @apna-rank/db db:generate",
    "db:migrate": "pnpm --filter @apna-rank/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @apna-rank/db db:migrate:deploy",
    "db:push": "pnpm --filter @apna-rank/db db:push",
    "db:studio": "pnpm --filter @apna-rank/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.2"
}
